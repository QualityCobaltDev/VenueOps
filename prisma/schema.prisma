generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChecklistType {
  OPENING
  CLOSING
  CLEANING
  CUSTOM
}

enum IncidentCategory {
  CUSTOMER_ISSUE
  STAFF_ISSUE
  INJURY
  THEFT
  AGGRESSION
  PROPERTY_DAMAGE
  INTOXICATION
  REFUSAL_OF_ENTRY
  EJECTION
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ShiftType {
  OPENING
  DAYTIME
  EVENING
  CLOSING
  OVERNIGHT
}

enum Priority {
  LOW
  NORMAL
  URGENT
}

enum TemplateCategory {
  OPERATIONS
  SECURITY
  STAFFING
  STOCK_CONTROL
  FINANCE
  SOPS
}

model Venue {
  id         String             @id @default(cuid())
  name       String
  users      User[]
  checklists Checklist[]
  incidents  IncidentReport[]
  dailyLogs  DailyLog[]
  templates  TemplateResource[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model User {
  id                     String          @id @default(cuid())
  fullName               String
  email                  String          @unique
  passwordHash           String
  venueId                String
  venue                  Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  completedChecklistItems ChecklistItem[] @relation("ChecklistItemCompleter")
  incidentReports        IncidentReport[] @relation("IncidentCreator")
  dailyLogs              DailyLog[]       @relation("LogCreator")
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([venueId])
}

model Checklist {
  id         String          @id @default(cuid())
  venueId    String
  venue      Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  title      String
  type       ChecklistType
  description String?
  isArchived Boolean         @default(false)
  items      ChecklistItem[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([venueId, isArchived])
}

model ChecklistItem {
  id                String    @id @default(cuid())
  checklistId       String
  checklist         Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  label             String
  sortOrder         Int
  isRequired        Boolean   @default(true)
  completedAt       DateTime?
  completedByUserId String?
  completedByUser   User?     @relation("ChecklistItemCompleter", fields: [completedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([checklistId, sortOrder])
}

model IncidentReport {
  id              String           @id @default(cuid())
  venueId         String
  venue           Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdByUser   User             @relation("IncidentCreator", fields: [createdByUserId], references: [id])
  title           String
  occurredAt      DateTime
  category        IncidentCategory
  severity        Severity
  location        String?
  peopleInvolved  String?
  description     String
  actionTaken     String?
  followUpRequired Boolean         @default(false)
  followUpNotes   String?
  isArchived      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([venueId, occurredAt])
  @@index([venueId, severity])
  @@index([venueId, category])
}

model DailyLog {
  id                String    @id @default(cuid())
  venueId           String
  venue             Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  createdByUserId   String
  createdByUser     User      @relation("LogCreator", fields: [createdByUserId], references: [id])
  title             String
  body              String
  shiftType         ShiftType
  priority          Priority
  operationalIssues String?
  staffingNotes     String?
  revenueNotes      String?
  followUpNeeded    Boolean   @default(false)
  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([venueId, createdAt])
}

model TemplateResource {
  id          String           @id @default(cuid())
  venueId     String?
  venue       Venue?           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  title       String
  description String
  category    TemplateCategory
  fileUrl     String
  isPublished Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([venueId, isPublished])
  @@index([category])
}
